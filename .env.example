# Gemini (Google AI Studio - free tier)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Redis (Upstash REST API - free tier) - guarda el estado de cada conversación
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
SESSION_TTL_SECONDS=3600

# SMTP - envío de la denuncia formal (opcional por ahora)
# Si dejas HOST/USER/PASSWORD vacíos, no se envía correo real: el backend imprime
# en los logs el correo que se habría enviado, y el flujo sigue normal.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="FaunaAlerta Bot <no-reply@tudominio.com>"

# Geocodificación (Nominatim/OpenStreetMap - gratis, sin API key, solo exige un User-Agent)
NOMINATIM_USER_AGENT="FaunaAlertaBot/1.0 (tu-correo@tudominio.com)"

# Entidades / envío
DEFAULT_FALLBACK_EMAIL=
# Si está definida, TODOS los correos se redirigen aquí (usar siempre en demo/desarrollo)
DEMO_OVERRIDE_EMAIL=

# CORS - dominio(s) del frontend que va a consumir esta API (separados por coma si son varios)
ALLOWED_ORIGIN=*
